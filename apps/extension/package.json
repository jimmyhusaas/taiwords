{
  "name": "taiwords-extension",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "TaiWords Chrome extension — detect mainland Chinese terms on any page",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "typescript": "^5.6.3",
    "wxt": "^0.19.13"
  }
}
